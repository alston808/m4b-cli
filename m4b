#!/usr/bin/env python3
import json
import subprocess
import os
import sys
import glob
import zipfile
import tempfile
import shutil
import urllib.request
import argparse

def get_source_bitrate(folder):
    # Scan recursively in case LibbyRip nested the audio files
    audio_files = glob.glob(os.path.join(folder, "**/*.mp3"), recursive=True)
    if not audio_files: return "64k"

    cmd = ["ffprobe", "-v", "0", "-show_entries", "stream=bit_rate", "-of", "compact=p=0:nk=1", audio_files[0]]
    try:
        bitrate_bps = subprocess.check_output(cmd).decode().strip()
        return f"{int(int(bitrate_bps) / 1000)}k"
    except: return "64k"

def find_file(filename, search_path):
    """Recursively search for a specific file to handle varying ZIP structures."""
    for root, _, files in os.walk(search_path):
        if filename in files:
            return os.path.join(root, filename)
    return None

def process_audiobook(target_dir, output_dir):
    json_path = find_file("metadata.json", target_dir)
    if not json_path:
        print("Error: Could not find metadata.json in the provided path.")
        return

    with open(json_path, 'r') as f:
        data = json.load(f)

    json_dir = os.path.dirname(json_path)

    # 1. Dynamic Cover Art Resolution
    cover_path = find_file("cover.jpg", target_dir)
    if not cover_path:
        cover_url = data.get("coverUrl")
        if cover_url:
            print("--- Downloading cover art from Libby CDN ---")
            cover_path = os.path.join(json_dir, "cover.jpg")
            try:
                # Disguise as a standard browser to prevent 403 blocks
                req = urllib.request.Request(cover_url, headers={'User-Agent': 'Mozilla/5.0'})
                with urllib.request.urlopen(req) as response, open(cover_path, 'wb') as out_file:
                    shutil.copyfileobj(response, out_file)
            except Exception as e:
                print(f"Warning: Failed to download cover - {e}")
                cover_path = None

    # 2. Calculate Absolute Chapter Timestamps
    spines = data.get("spine", [])
    chapters = data.get("chapters", [])

    spine_starts = []
    current_time_sec = 0.0
    for s in spines:
        spine_starts.append(current_time_sec)
        current_time_sec += float(s.get("duration", 0.0))

    chapters_txt_path = os.path.join(target_dir, "chapters.txt")
    with open(chapters_txt_path, 'w') as f:
        for chap in chapters:
            spine_idx = chap.get("spine", 0)
            offset = float(chap.get("offset", 0.0))

            base_time = spine_starts[spine_idx] if spine_idx < len(spine_starts) else 0.0
            abs_time = base_time + offset

            h = int(abs_time // 3600)
            m = int((abs_time % 3600) // 60)
            s = abs_time % 60

            title = chap.get("title", "Unknown Chapter")
            f.write(f"{h:02d}:{m:02d}:{s:06.3f} {title}\n")

    # 3. Extract Metadata Dynamically
    title = data.get("title", "Unknown Title")
    creators = data.get("creator", [])
    author = next((c["name"] for c in creators if c.get("role") == "author"), "Unknown Author")
    narrator = next((c["name"] for c in creators if c.get("role") == "narrator"), "")

    description = data.get("description", {}).get("full", "").replace("<p>", "").replace("</p>", "\n").strip()
    bitrate = get_source_bitrate(target_dir)

    # Secure title for filesystem output
    safe_title = "".join([c for c in title if c.isalpha() or c.isdigit() or c==' ']).rstrip().replace(" ", "_")
    final_output_name = f"{safe_title}.m4b"
    final_output_path = os.path.join(output_dir, final_output_name)

    cover_in_container = f"/mnt/{os.path.relpath(cover_path, target_dir)}" if cover_path else ""

    # 4. Audio Merge & Compression via m4b-tool
    m4b_cmd = [
        "podman", "run", "-it", "--rm",
        "-v", f"{os.path.abspath(target_dir)}:/mnt:Z",
        "--userns=keep-id",
        "sandreas/m4b-tool", "merge", "/mnt",
        "--output-file=/mnt/audiobook_final.m4b",
        f"--audio-bitrate={bitrate}",
        "--audio-codec=libfdk_aac",
        "--skip-cover"
    ]

    print(f"--- Merging and Encoding Audio: {title} ---")
    subprocess.run(m4b_cmd)

    # 5. Precision Metadata Tagging via Tone
    tone_cmd = [
        "podman", "run", "-it", "--rm",
        "-v", f"{os.path.abspath(target_dir)}:/mnt:Z",
        "--userns=keep-id",
        "sandreas/tone:v0.2.5", "tag", "/mnt/audiobook_final.m4b",
        f"--meta-title={title}",
        f"--meta-artist={author}",
        f"--meta-description={description}"
    ]

    if cover_in_container:
        tone_cmd.append(f"--cover={cover_in_container}")
    if narrator:
        tone_cmd.append(f"--meta-narrator={narrator}")

    print(f"--- Finalizing Metadata with Tone: {title} ---")
    subprocess.run(tone_cmd)

    # 6. Move output from ephemeral storage to target directory
    generated_m4b = os.path.join(target_dir, "audiobook_final.m4b")
    if os.path.exists(generated_m4b):
        shutil.move(generated_m4b, final_output_path)
        print(f"\n--- Success! ---")
        print(f"Output saved to: {final_output_path}")
    else:
        print("\n--- Error: M4B generation failed. Check Podman logs. ---")

def main():
    parser = argparse.ArgumentParser(description="Automated M4B builder from raw directories or LibbyRip ZIP exports.")
    parser.add_argument("input_path", help="Path to the directory or ZIP file containing the audiobook.")
    parser.add_argument("-o", "--output", help="Destination folder for the final M4B. Defaults to current directory.", default=os.getcwd())
    args = parser.parse_args()

    input_path = os.path.abspath(args.input_path)
    output_dir = os.path.abspath(args.output)

    if not os.path.exists(input_path):
        print(f"Error: Path '{input_path}' does not exist.")
        sys.exit(1)

    if os.path.isfile(input_path) and input_path.lower().endswith(".zip"):
        print(f"--- Unpacking Archive: {os.path.basename(input_path)} ---")
        # Extract to ephemeral storage that auto-deletes when done
        with tempfile.TemporaryDirectory() as temp_dir:
            with zipfile.ZipFile(input_path, 'r') as zip_ref:
                zip_ref.extractall(temp_dir)
            process_audiobook(temp_dir, output_dir)
    elif os.path.isdir(input_path):
        process_audiobook(input_path, output_dir)
    else:
        print("Error: Input must be an uncompressed directory or a .zip file.")
        sys.exit(1)

if __name__ == "__main__":
    main()
